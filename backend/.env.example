# Backend runtime
PORT=3000
DATABASE_URL=postgres://anshbhatt@localhost:5432/gridwatch
REDIS_URL=redis://localhost:6379/0

# Auth
# Leave empty to use development header-auth fallback.
JWT_SECRET=
INGEST_API_KEY=

# Rate limiting
INGEST_RATE_LIMIT=120
AUTH_RATE_LIMIT=300
RATE_LIMIT_WINDOW_MS=60000

# Test runner (host machine)
TEST_DATABASE_URL=postgres://anshbhatt@localhost:5432/gridwatch_test

# Test toggles (usually set automatically by tests/setup-env.ts)
DISABLE_QUEUES=0
DISABLE_REDIS_IDEMPOTENCY=0
